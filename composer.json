{
    "name": "contenir/formbuilder",
    "description": "Framework-agnostic form-builder engine for Contenir CMS — runtime-editable form definitions, builder-form construction, server-side submission validation.",
    "type": "library",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../storage",
            "canonical": false,
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3",
        "laminas/laminas-form": "^3.20",
        "laminas/laminas-inputfilter": "^2.30",
        "laminas/laminas-validator": "^2.50 || ^3.0",
        "laminas/laminas-filter": "^2.30",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "contenir/storage": "^0.1.0",
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "suggest": {
        "contenir/storage": "Required for the file field type. Pass a Contenir\\Storage\\StorageManager into FormSubmissionService when uploads need to land on a configured storage profile."
    },
    "autoload": {
        "psr-4": { "Contenir\\FormBuilder\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Contenir\\FormBuilder\\Tests\\": "tests/" }
    },
    "scripts": {
        "test": "phpunit",
        "cs": "phpcs",
        "cs-fix": "phpcbf"
    },
    "config": {
        "sort-packages": true
    }
}